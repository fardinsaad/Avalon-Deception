# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Jupyter notebooks
*.ipynb text eol=lf

# CSV files
*.csv text eol=lf

# Python files
*.py text eol=lf

# Markdown files
*.md text eol=lf

# LaTeX files
*.tex text eol=lf
*.bib text eol=lf

# JSON files
*.json text eol=lf

# Text files
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
